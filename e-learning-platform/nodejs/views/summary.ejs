<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Quiz Summary</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 600px; margin: auto; padding: 20px; text-align: center; }
        .result { padding: 30px; border-radius: 10px; margin: 20px 0; }
        .passed { background: #d4edda; border: 1px solid #c3e6cb; }
        .failed { background: #f8d7da; border: 1px solid #f5c6cb; }
        .score { font-size: 48px; font-weight: bold; }
        .label { font-size: 24px; margin: 10px 0; }
        .details { margin-top: 20px; font-size: 16px; }
        a { display: inline-block; margin-top: 20px; color: #007bff; text-decoration: none; }
    </style>
</head>
<body>
    <div class="result <%= result.passed ? 'passed' : 'failed' %>">
        <div class="score"><%= result.percentage.toFixed(1) %>%</div>
        <div class="label"><%= result.passed ? 'PASSED' : 'FAILED' %></div>
        <div class="details">
            <p>Score: <%= result.score.toFixed(1) %> / <%= result.total %></p>
            <p>Correct: <%= result.correct %> | Wrong: <%= result.wrong %> | Total: <%= result.total %></p>
        </div>
    </div>
    <a href="/quiz">Try Again</a>
</body>
</html>
