<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Zajęcia Fitness - Harmonogram</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        :root {
            --bg-color: #0b0f19;
            --card-bg: rgba(22, 30, 49, 0.7);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-primary: #f3f4f6;
            --text-secondary: #9ca3af;
            --primary-gradient: linear-gradient(135deg, #6366f1, #8b5cf6);
            --success-color: #10b981;
            --fail-color: #ef4444;
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            margin: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            box-sizing: border-box;
        }
        .container {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 35px;
            width: 100%;
            max-width: 900px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }
        h1 {
            font-size: 26px;
            font-weight: 700;
            margin-top: 0;
            margin-bottom: 25px;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
        }
        .message {
            background: rgba(99, 102, 241, 0.1);
            border: 1px solid rgba(99, 102, 241, 0.3);
            color: #a5b4fc;
            padding: 12px 18px;
            margin-bottom: 25px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            text-align: center;
        }
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-bottom: 10px;
        }
        th {
            background: rgba(255, 255, 255, 0.03);
            font-weight: 600;
            text-align: left;
            padding: 14px 16px;
            color: #fff;
            border-bottom: 1px solid var(--border-color);
            font-size: 14px;
        }
        td {
            padding: 14px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            color: var(--text-secondary);
            font-size: 14px;
        }
        tr:hover td {
            background: rgba(255, 255, 255, 0.01);
            color: #fff;
        }
        tr:last-child td {
            border-bottom: none;
        }
        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            color: white;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.2s ease;
            margin-right: 6px;
        }
        .btn-register {
            background: #10b981;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        }
        .btn-register:hover {
            background: #059669;
            transform: translateY(-1px);
        }
        .btn-unregister {
            background: #ef4444;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
        }
        .btn-unregister:hover {
            background: #dc2626;
            transform: translateY(-1px);
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Tygodniowy Grafik Zajęć Fitness</h1>

        <% if (message) { %>
        <div class="message"><%= message %></div>
        <% } %>

        <table>
            <thead>
                <tr>
                    <th>Dzień</th>
                    <th>Godzina</th>
                    <th>Zajęcia</th>
                    <th>Miejsca (Max)</th>
                    <th>Akcja</th>
                </tr>
            </thead>
            <tbody>
                <% classes.forEach(function(c) { %>
                <tr>
                    <td style="font-weight: 500; color: #fff;"><%= c.dayOfWeek %></td>
                    <td><%= c.time %></td>
                    <td style="font-weight: 600; color: #a5b4fc;"><%= c.type %></td>
                    <td><%= c.maxCapacity %></td>
                    <td>
                        <form action="/fitness/register/<%= c.id %>" method="post" style="display:inline">
                            <button type="submit" class="btn btn-register">Zapisz się</button>
                        </form>
                        <form action="/fitness/unregister/<%= c.id %>" method="post" style="display:inline">
                            <button type="submit" class="btn btn-unregister">Wypisz się</button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</body>
</html>
